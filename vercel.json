{
  "framework": "nextjs",
  "regions": ["cdg1"],
  "buildCommand": "npm run build",
  "installCommand": "npm ci",
  "env": {
    "NEXT_TELEMETRY_DISABLED": "1"
  },
  "crons": [
    { "path": "/api/cron/poll-traxbean", "schedule": "0 6 * * *" },
    { "path": "/api/cron/measure-reminders", "schedule": "0 7 * * *" }
  ]
}
