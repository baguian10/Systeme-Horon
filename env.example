# Supabase — required for real auth + database
# Without these, the app runs in demo mode with mock data
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — used only server-side by SUPER_ADMIN operations (bypasses RLS)
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Site URL — used for auth callbacks (set to your Vercel URL in production)
NEXT_PUBLIC_SITE_URL=http://localhost:3000
