# ── Supabase ──────────────────────────────────────────────────────────────────
# Without these, the app runs in demo mode with mock data (no database required)
NEXT_PUBLIC_SUPABASE_URL=https://your-project-ref.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Service role key — server-side only, bypasses RLS (SUPER_ADMIN operations)
# Never expose this to the client
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Site URL ──────────────────────────────────────────────────────────────────
# Used for auth callbacks and canonical links
# Set to your Vercel production URL in deployment environment variables
NEXT_PUBLIC_SITE_URL=https://your-project.vercel.app

# ── Device ingest authentication ──────────────────────────────────────────────
# Shared secret sent by ThinkRace TR40 devices via x-api-key header
# Required in production — generate with: openssl rand -hex 32
INGEST_API_KEY=your-random-64-char-hex-secret

# ── Traxbean / ThinkRace cloud (TR40 ankle tracker) ───────────────────────────
# The TR40 reports to the Traxbean platform; we poll it and feed positions into
# /api/ingest/position. Base host of the platform API.
TRAXBEAN_API_BASE=https://napi.5gcity.com
# Long-lived JWT captured from the platform session (Authorization header value).
# No `exp` claim; rotate by re-capturing from the dashboard if it stops working.
TRAXBEAN_TOKEN=your-traxbean-jwt
# Demo-mode only: overlay this IMEI's live position onto the first map marker.
TRAXBEAN_DEMO_IMEI=355932600157247

# ── Cron poll authentication ──────────────────────────────────────────────────
# Secret guarding GET /api/cron/poll-traxbean. The external pinger (cron-job.org)
# must send it as ?secret=... or Authorization: Bearer <secret>.
CRON_SECRET=your-random-cron-secret
